{
	"name": "md-to-halo",
	"version": "1.1.2",
	"description": "Publish Markdown notes from Obsidian to Halo blog",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"halo",
		"blog",
		"publish",
		"markdown"
	],
	"author": "Yakumo2",
	"license": "MIT",
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"axios": "^1.8.4",
		"js-yaml": "^4.1.0",
		"markdown-it": "^14.1.0"
	}
}
